{
    "version": "2.0.0",
    "configurations": [
        {
            "name": "simao launch C/C++: cmake build and debug active file",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/../build/${fileBasenameNoExtension}",
            "args": ["10", "4", "4"],
            "stopAtEntry": false,  // Stop at the entry point to ensure breakpoints are hit
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "preLaunchTask": "Build simao",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
